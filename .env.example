# Production canonical URL. REQUIRED on Vercel production — build throws
# without it. Preview deploys auto-fall-back to VERCEL_URL; local dev
# falls back to http://localhost:3000. Set to the apex domain only:
#   NEXT_PUBLIC_SITE_URL=https://sp-automotive.com
NEXT_PUBLIC_SITE_URL=

# Analytics. All optional — each tracker no-ops if its var is missing.
# GTM container ID, e.g. GTM-XXXXXXX. Loads GA4 via a tag inside the container.
NEXT_PUBLIC_GTM_ID=
# Microsoft Clarity project ID, e.g. abcd1234efg.
NEXT_PUBLIC_CLARITY_ID=

# Contact form (Phase A1). All required for the contact form to function.
# Resend API key for transactional email to Serge.
RESEND_API_KEY=
# Where the contact form notification email lands.
CONTACT_RECIPIENT_EMAIL=
# From: address for the email. Must be on a verified Resend domain.
CONTACT_FROM_EMAIL=
# Apps Script Web App URL deployed in the shared agency workspace.
SHEET_WEBHOOK_URL=
# Vercel Blob read/write token (auto-injected when Blob is linked to the project).
BLOB_READ_WRITE_TOKEN=
